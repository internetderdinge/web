{
  "name": "@internetderdinge/web",
  "version": "1.224.2",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-i18next": ">=11",
    "react-responsive": ">=9"
  },
  "devDependencies": {
    "rimraf": "^5.0.7",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2"
  }
}
